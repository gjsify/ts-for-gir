      <function name="duplicate"
                c:identifier="gimp_param_spec_object_duplicate">
        <doc xml:space="preserve"
             filename="libgimpbase/gimpparamspecs.c"
             line="201">This function duplicates @pspec appropriately, depending on the
accurate spec type.</doc>
        <source-position filename="libgimpbase/gimpparamspecs.h" line="152"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimpbase/gimpparamspecs.c"
               line="208">a newly created param spec.</doc>
