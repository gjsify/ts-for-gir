            <doc xml:space="preserve"
                 filename="libmalcontent/session-limits.c"
                 line="789">true if the limit type is to be enforced, false if the value is
  just being stored for future use without being enforced</doc>
            <type name="gboolean" c:type="gboolean"/>
          </parameter>
          <parameter name="daily_limit_secs" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libmalcontent/session-limits.c"
