      <method name="set_colormap"
              c:identifier="gimp_palette_set_colormap"
              version="3.0">
        <doc xml:space="preserve"
             filename="libgimp/gimppalette.c"
             line="96">This procedure sets the entries in the specified palette in one go,
though they must all be in the same @format.

The number of entries depens on the @num_bytes size of @colormap and
the bytes-per-pixel size of @format.
The procedure will fail if @num_bytes is not an exact multiple of the
number of bytes per pixel of @format.</doc>
        <source-position filename="libgimp/gimppalette.h" line="46"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimp/gimppalette.c"
               line="111">%TRUE on success.</doc>
          <type name="gboolean" c:type="gboolean"/>
        </return-value>
        <parameters>
          <instance-parameter name="palette" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimppalette.c"
                 line="98">The palette.</doc>
            <type name="Palette" c:type="GimpPalette*"/>
          </instance-parameter>
          <parameter name="format" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimppalette.c"
                 line="99">The desired color format.
@colormap (array length=num_bytes): The new colormap values.</doc>
            <type name="Babl.Object" c:type="const Babl*"/>
          </parameter>
          <parameter name="colormap" transfer-ownership="none">
            <type name="guint8" c:type="guint8*"/>
          </parameter>
          <parameter name="num_bytes" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimppalette.c"
                 line="101">The byte-size of @colormap.</doc>
            <type name="gsize" c:type="gsize"/>
          </parameter>
        </parameters>
      </method>
