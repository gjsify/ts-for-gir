{
	"name": "@ts-for-gir/cli",
	"version": "4.0.0-rc.9",
	"description": "TypeScript type definition generator for GObject introspection GIR files",
	"main": "src/index.ts",
	"module": "src/index.ts",
	"type": "module",
	"bin": {
		"cli": "bin/ts-for-gir",
		"ts-for-gir": "bin/ts-for-gir",
		"ts-for-gir-dev": "bin/ts-for-gir-dev",
		"ts-for-gir-gjs": "bin/ts-for-gir-gjs"
	},
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"start": "node bin/ts-for-gir-dev",
		"start:prod": "node bin/ts-for-gir",
		"bundle-templates": "node --experimental-strip-types --no-warnings scripts/bundle-templates.ts",
		"build": "yarn bundle-templates && node --experimental-specifier-resolution=node --experimental-strip-types --experimental-transform-types --no-warnings esbuild.ts && chmod +x bin/ts-for-gir-dev && chmod +x bin/ts-for-gir",
		"build:gjs": "yarn bundle-templates && node --experimental-strip-types --no-warnings scripts/build-gjs.ts",
		"build:templates": "node scripts/process-templates.mjs",
		"prepack": "node scripts/process-templates.mjs",
		"check:types": "tsc --noEmit",
		"check": "yarn check:types"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gjsify/ts-for-gir.git"
	},
	"author": "Pascal Garber <pascal@mailfreun.de>",
	"files": [
		"src",
		"bin",
		"dist-templates"
	],
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/gjsify/ts-for-gir/issues"
	},
	"homepage": "https://github.com/gjsify/ts-for-gir#readme",
	"keywords": [
		"gjs",
		"typescript",
		"generate",
		"gir",
		"gobject-introspection",
		"gnome",
		"gtk",
		"glib",
		"gobject",
		"dts",
		"type definitions",
		"cli"
	],
	"exports": {
		".": "./src/index.ts"
	},
	"devDependencies": {
		"@gi.ts/parser": "workspace:^",
		"@gjsify/async_hooks": "^0.2.0",
		"@gjsify/buffer": "^0.2.0",
		"@gjsify/child_process": "^0.2.0",
		"@gjsify/cli": "^0.2.0",
		"@gjsify/empty": "^0.2.0",
		"@gjsify/esbuild-plugin-gjsify": "^0.2.0",
		"@gjsify/events": "^0.2.0",
		"@gjsify/fs": "^0.2.0",
		"@gjsify/module": "^0.2.0",
		"@gjsify/node-polyfills": "^0.2.0",
		"@gjsify/os": "^0.2.0",
		"@gjsify/path": "^0.2.0",
		"@gjsify/process": "^0.2.0",
		"@gjsify/readline": "^0.2.0",
		"@gjsify/stream": "^0.2.0",
		"@gjsify/url": "^0.2.0",
		"@gjsify/util": "^0.2.0",
		"@ts-for-gir/generator-base": "workspace:^",
		"@ts-for-gir/generator-html-doc": "workspace:^",
		"@ts-for-gir/generator-json": "workspace:^",
		"@ts-for-gir/generator-typescript": "workspace:^",
		"@ts-for-gir/lib": "workspace:^",
		"@ts-for-gir/reporter": "workspace:^",
		"@ts-for-gir/tsconfig": "workspace:^",
		"@types/ejs": "^3.1.5",
		"@types/inquirer": "^9.0.9",
		"@types/node": "^25.6.0",
		"@types/yargs": "^17.0.35",
		"esbuild": "^0.28.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.4.2",
		"@ts-for-gir/templates": "workspace:^",
		"colorette": "^2.0.20",
		"cosmiconfig": "^9.0.1",
		"ejs": "^5.0.2",
		"glob": "^13.0.6",
		"inquirer": "^13.4.2",
		"typedoc": "^0.28.19",
		"yargs": "^18.0.0"
	}
}
