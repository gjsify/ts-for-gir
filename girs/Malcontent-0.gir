        </return-value>
        <parameters>
          <instance-parameter name="limits" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libmalcontent/session-limits.c"
                 line="133">a [struct@Malcontent.SessionLimits]</doc>
            <type name="SessionLimits" c:type="MctSessionLimits*"/>
          </instance-parameter>
          <parameter name="out_start_time_secs"
                     direction="out"
                     caller-allocates="0"
                     transfer-ownership="full"
