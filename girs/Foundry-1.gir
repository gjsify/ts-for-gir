      <method name="load_untracked_delta"
              c:identifier="foundry_git_commit_builder_load_untracked_delta"
              version="1.1">
        <doc xml:space="preserve"
             filename="libfoundry/git/foundry-git-commit-builder.c"
             line="2499">Loads the delta for an untracked @file. This creates a synthetic delta
that represents adding the entire file, allowing the same API semantics
for new files as for modified files. The delta can be used to toggle
individual lines on/off for staging in the background.

The file must be untracked (not in git's index) when the commit builder
was created. Since untracked files are new files, the delta will contain
a single hunk with all lines marked as additions.</doc>
        <source-position filename="libfoundry/git/foundry-git-commit-builder.h"
                         line="97"/>
        <return-value transfer-ownership="full">
          <doc xml:space="preserve"
               filename="libfoundry/git/foundry-git-commit-builder.c"
               line="2513">a [class@Dex.Future] that resolves to
  a [class@Foundry.GitDelta] or rejects with error.</doc>
          <type name="Dex.Future" c:type="DexFuture*"/>
        </return-value>
        <parameters>
          <instance-parameter name="self" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libfoundry/git/foundry-git-commit-builder.c"
                 line="2501">a [class@Foundry.GitCommitBuilder]</doc>
            <type name="GitCommitBuilder" c:type="FoundryGitCommitBuilder*"/>
          </instance-parameter>
          <parameter name="file" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libfoundry/git/foundry-git-commit-builder.c"
                 line="2502">a [iface@Gio.File] in the working tree</doc>
            <type name="Gio.File" c:type="GFile*"/>
          </parameter>
        </parameters>
      </method>
