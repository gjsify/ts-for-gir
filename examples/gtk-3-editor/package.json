{
	"name": "@ts-for-gir-example/gtk-3-editor-example",
	"type": "module",
	"targets": {
		".": {
			"context": "node",
			"outputFormat": "esmodule",
			"includeNodeModules": [
				"@girs/gjs",
				"@girs/gtk-3.0",
				"@girs/gtksource-3.0"
			],
			"sourceMap": false
		}
	},
	"private": true,
	"scripts": {
		"build": "parcel build main.ts",
		"watch": "yarn build --watch",
		"start": "gjs -m dist/main.js",
		"check": "tsc --noEmit",
		"clear": "rm -rf dist .parcel-cache @types"
	},
	"author": "",
	"license": "Apache-2.0",
	"devDependencies": {
		"@parcel/config-default": "^2.16.4",
		"@parcel/plugin": "^2.16.4",
		"@parcel/resolver-default": "^2.16.4",
		"parcel": "^2.16.4",
		"parcel-plugin-externals": "^0.5.2",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@girs/gjs": "workspace:^",
		"@girs/gtk-3.0": "workspace:^",
		"@girs/gtksource-3.0": "workspace:^"
	},
	"externals": [
		"gi://Gtk?version=3.0",
		"gi://GtkSource?version=3.0"
	]
}
