          </instance-parameter>
          <parameter name="filter" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimpdrawable.c"
                 line="470">The drawable filter to merge.</doc>
            <type name="DrawableFilter" c:type="GimpDrawableFilter*"/>
          </parameter>
        </parameters>
      </method>
