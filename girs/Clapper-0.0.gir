                default-value="0">
        <doc xml:space="preserve"
             filename="src/lib/clapper/clapper-player.c"
             line="2936">A minimal allowed bitrate (bits/s) during adaptive streaming
such as DASH or HLS.

Setting this will prevent streaming from entering lower qualities
(even when connection speed cannot keep up). When set together with
[property@Clapper.Player:adaptive-max-bitrate] it can be used to
enforce some specific quality.</doc>
        <type name="guint" c:type="guint"/>
      </property>
      <property name="adaptive-start-bitrate"
                version="0.8"
