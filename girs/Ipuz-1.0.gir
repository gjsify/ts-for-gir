      <method name="clue_set_next_direction"
              c:identifier="ipuz_clues_clue_set_next_direction">
        <doc xml:space="preserve"
             filename="libipuz/docs/ipuz-clues-docs.c"
             line="187">Returns the next clue set visible in @clues after @direction.

For example, if called on a regular crossword with a @direction of
[enum@Ipuz.ClueDirection.ACROSS], this would return
[enum@Ipuz.ClueDirection.DOWN].

If @wrap is %TRUE then this will wrap around to the beginning when
at the last visible clue sets, otherwise it will return
[enum@Ipuz.ClueDirection.NONE].

Note that any clue sets of type [enum@Ipuz.ClueDirection.HIDDEN]
will be skipped by this function.</doc>
        <source-position filename="libipuz/ipuz-clues.h" line="116"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libipuz/docs/ipuz-clues-docs.c"
               line="205">The next direction logically in @clues, or
[enum@Ipuz.ClueDirection.NONE]</doc>
          <type name="ClueDirection" c:type="IpuzClueDirection"/>
        </return-value>
        <parameters>
          <instance-parameter name="clues" transfer-ownership="none">
            <type name="Clues" c:type="IpuzClues*"/>
          </instance-parameter>
          <parameter name="direction" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libipuz/docs/ipuz-clues-docs.c"
                 line="189">A direction</doc>
            <type name="ClueDirection" c:type="IpuzClueDirection"/>
          </parameter>
          <parameter name="wrap" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libipuz/docs/ipuz-clues-docs.c"
                 line="190">Whether to wrap around</doc>
            <type name="gboolean" c:type="gboolean"/>
          </parameter>
        </parameters>
      </method>
