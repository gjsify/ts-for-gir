             line="214">Returns the list of [class@Meta.Monitor]s.</doc>
        <source-position filename="src/meta/meta-logical-monitor.h" line="32"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="src/backends/meta-logical-monitor.c"
               line="220">
The list of [class@Meta.Monitor]s.</doc>
          <type name="GLib.List" c:type="GList*">
            <type name="Monitor"/>
          </type>
        </return-value>
        <parameters>
          <instance-parameter name="logical_monitor" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="src/backends/meta-logical-monitor.c"
                 line="216">A #MetaLogicalMonitor</doc>
