                         line="41"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimp/gimpimagetransform_pdb.c"
               line="142">TRUE on success.</doc>
          <type name="gboolean" c:type="gboolean"/>
        </return-value>
        <parameters>
