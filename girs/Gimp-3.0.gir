    <class name="DrawableFilter"
           c:symbol-prefix="drawable_filter"
           c:type="GimpDrawableFilter"
           parent="GObject.Object"
           glib:type-name="GimpDrawableFilter"
           glib:get-type="gimp_drawable_filter_get_type"
           glib:type-struct="DrawableFilterClass">
      <doc xml:space="preserve"
           filename="libgimp/gimpdrawablefilter_pdb.c"
           line="30">Operations on drawable filters: creation, editing.</doc>
      <source-position filename="libgimp/gimpdrawablefilter.h" line="36"/>
      <constructor name="new"
                   c:identifier="gimp_drawable_filter_new"
                   version="3.0">
        <doc xml:space="preserve"
             filename="libgimp/gimpdrawablefilter_pdb.c"
             line="76">Create a new drawable filter.

This procedure creates a new filter for the specified operation on
@drawable.
The new effect still needs to be either added or merged to @drawable
later. Add the effect non-destructively with
[method@Gimp.Drawable.append_filter].
Currently only layers can have non-destructive effects. The effects
must be merged for all other types of drawable.</doc>
        <source-position filename="libgimp/gimpdrawablefilter_pdb.h"
                         line="36"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimp/gimpdrawablefilter_pdb.c"
               line="92">The newly created filter.</doc>
          <type name="DrawableFilter" c:type="GimpDrawableFilter*"/>
        </return-value>
        <parameters>
          <parameter name="drawable" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimpdrawablefilter_pdb.c"
                 line="78">The drawable.</doc>
            <type name="Drawable" c:type="GimpDrawable*"/>
          </parameter>
          <parameter name="operation_name" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimpdrawablefilter_pdb.c"
                 line="79">The GEGL operation's name.</doc>
            <type name="utf8" c:type="const gchar*"/>
          </parameter>
          <parameter name="name"
                     transfer-ownership="none"
                     nullable="1"
                     allow-none="1">
            <doc xml:space="preserve"
                 filename="libgimp/gimpdrawablefilter_pdb.c"
                 line="80">The effect name.</doc>
            <type name="utf8" c:type="const gchar*"/>
          </parameter>
        </parameters>
      </constructor>
