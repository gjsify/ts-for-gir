              version="3.0">
      <doc xml:space="preserve"
           filename="libgimp/gimpexportprocedure.h"
           line="66">This function returns the capabilities requested by your export
procedure, depending on @config or @options.</doc>
      <source-position filename="libgimp/gimpexportprocedure.h" line="82"/>
      <return-value transfer-ownership="none">
        <doc xml:space="preserve"
             filename="libgimp/gimpexportprocedure.h"
