                 filename="libipuz/docs/ipuz-crossword-docs.c"
                 line="218">the symmetry condition to enforce</doc>
            <type name="Symmetry" c:type="IpuzSymmetry"/>
          </parameter>
          <parameter name="symmetry_coords" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libipuz/docs/ipuz-crossword-docs.c"
                 line="219">A #GArray of #IpuzCellCoords</doc>
            <array name="GLib.Array" c:type="GArray*">
              <type name="CellCoord"/>
            </array>
          </parameter>
