{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnknownTypeSelector": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 120
	},
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/build",
			"!**/tmp",
			"!**/test",
			"!**/tests",
			"!**/templates",
			"!**/@types",
			"!**/docs",
			"!refs",
			"!types-dev",
			"!types-release",
			"!**/vala-girs",
			"!**/*.js",
			"!**/*.mjs",
			"!**/*.cjs",
			"!**/.*",
			"!**/*.json",
			"!json"
		]
	}
}
