{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/*.json",
    "**/*.jsonc",
    "**/*.json5",
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "**/*.less",
    "**/*.html",
    "**/*.htm",
    "**/*.md",
    "**/*.mdx",
    "**/*.yml",
    "**/*.yaml",
    "**/*.toml",
    "**/*.graphql",
    "**/*.gql",
    "**/*.gir",
    "**/node_modules",
    "**/dist",
    "**/lib",
    "**/build",
    "**/coverage",
    "refs",
    "**/refs",
    "docs",
    "**/docs",
    "types-dev",
    "types-release",
    "girs",
    "json",
    "**/@types",
    "**/templates",
    "**/dist-templates",
    "**/src/generated",
    "**/*.gjs.mjs",
    "**/.flatpak-builder"
