          <parameter name="thumbnail_proc" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimploadprocedure.c"
                 line="438">The name of the thumbnail load procedure.</doc>
            <type name="utf8" c:type="const gchar*"/>
          </parameter>
        </parameters>
      </method>
