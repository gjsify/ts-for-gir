          <type name="ClueId" c:type="IpuzClueId*"/>
        </return-value>
        <parameters>
          <instance-parameter name="clue_id" transfer-ownership="none">
            <type name="ClueId" c:type="const IpuzClueId*"/>
          </instance-parameter>
        </parameters>
      </method>
      <method name="equal" c:identifier="ipuz_clue_id_equal">
