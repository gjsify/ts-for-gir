                 filename="libgimp/gimppath_pdb.c"
                 line="260">The precision used for the approximation.</doc>
            <type name="gdouble" c:type="gdouble"/>
          </parameter>
          <parameter name="x_point"
                     direction="out"
                     caller-allocates="0"
