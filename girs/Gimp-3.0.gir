    <class name="VectorLayer"
           c:symbol-prefix="vector_layer"
           c:type="GimpVectorLayer"
           parent="Layer"
           glib:type-name="GimpVectorLayer"
           glib:get-type="gimp_vector_layer_get_type"
           glib:type-struct="VectorLayerClass">
      <doc xml:space="preserve"
           filename="libgimp/gimpvectorlayer_pdb.c"
           line="30">Functions for querying and manipulating vector layers.</doc>
      <source-position filename="libgimp/gimpvectorlayer.h" line="37"/>
      <implements name="Rasterizable"/>
      <constructor name="new"
                   c:identifier="gimp_vector_layer_new"
                   version="3.2">
        <doc xml:space="preserve"
             filename="libgimp/gimpvectorlayer_pdb.c"
             line="39">Create a new vector layer.

This procedure creates a new vector layer displaying the specified
@path. By default, the fill and stroke properties will be defined by
the context.

The new layer still needs to be added to the image as this is not
automatic. Add the new layer with the [method@Image.insert_layer]
method.

The arguments are kept as simple as necessary for the basic case.
All vector attributes, however, can be modified with the appropriate
`gimp_vector_layer_set_*()` procedures.</doc>
        <source-position filename="libgimp/gimpvectorlayer_pdb.h" line="35"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimp/gimpvectorlayer_pdb.c"
               line="58">
         The new vector layer. The object belongs to libgimp and you should not free it.</doc>
          <type name="VectorLayer" c:type="GimpVectorLayer*"/>
        </return-value>
        <parameters>
          <parameter name="image" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimpvectorlayer_pdb.c"
                 line="41">The image.</doc>
            <type name="Image" c:type="GimpImage*"/>
          </parameter>
          <parameter name="path" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimpvectorlayer_pdb.c"
                 line="42">The path to create the layer from.</doc>
            <type name="Path" c:type="GimpPath*"/>
          </parameter>
        </parameters>
      </constructor>
