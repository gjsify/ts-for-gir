                 filename="libgimp/gimpimageconvert_pdb.c"
                 line="216">The image.</doc>
            <type name="Image" c:type="GimpImage*"/>
          </instance-parameter>
          <parameter name="precision" transfer-ownership="none">
            <doc xml:space="preserve"
