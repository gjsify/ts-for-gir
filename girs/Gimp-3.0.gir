             line="1187">TRUE on success.</doc>
        <type name="gboolean" c:type="gboolean"/>
      </return-value>
      <parameters>
        <parameter name="num_dashes" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimp/gimpcontext_pdb.c"
               line="1172">The number of dashes in the dash_pattern array.</doc>
          <type name="gsize" c:type="gsize"/>
        </parameter>
        <parameter name="dashes" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimp/gimpcontext_pdb.c"
               line="1173">The line dash pattern setting.</doc>
          <array length="0" zero-terminated="0" c:type="const gdouble*">
            <type name="gdouble"/>
          </array>
        </parameter>
      </parameters>
    </function>
