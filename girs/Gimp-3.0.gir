                     transfer-ownership="none"
                     nullable="1"
                     allow-none="1">
            <doc xml:space="preserve"
                 filename="libgimpbase/gimpparamspecs.c"
                 line="163">a default value.</doc>
            <type name="GObject.Object" c:type="GObject*"/>
          </parameter>
        </parameters>
