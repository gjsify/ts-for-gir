{
	"name": "ts-for-gir",
	"version": "4.0.0-rc.2",
	"description": "Typescript .d.ts generator from GIR for gjs",
	"type": "module",
	"private": true,
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"clear": "yarn workspaces foreach -v --all --parallel run clear",
		"start": "ts-for-gir-dev",
		"start:prod": "yarn ts-for-gir",
		"format": "biome check . --write --unsafe",
		"build:app": "yarn workspace @ts-for-gir/cli run build",
		"build:examples": "yarn workspaces foreach -v --all --include '@ts-for-gir-example/*' --parallel run build",
		"build:types": "ts-for-gir-dev generate --configName='.ts-for-gir.packages-all.rc.js' --workspace=true --outdir='./types-dev' && yarn install",
		"build:types:release": "ts-for-gir-dev generate --configName='.ts-for-gir.packages-all.rc.js' --outdir='./types-release'",
		"build:json": "ts-for-gir-dev json --configName='.ts-for-gir.doc.rc.js' --outdir='./json'",
		"build:doc": "ts-for-gir-dev doc --configName='.ts-for-gir.doc.rc.js'",
		"build": "yarn build:app && yarn build:types && yarn build:examples && yarn build:json && yarn build:doc",
		"list:girs": "ts-for-gir-dev list --configName='.ts-for-gir.packages-all.rc.js'",
		"copy:girs": "ts-for-gir-dev copy --configName='.ts-for-gir.copy-all.rc.js' --verbose",
		"check:lint": "biome check .",
		"check:examples": "yarn workspaces foreach -v --all --include '@ts-for-gir-example/*' --parallel run check",
		"check:types": "yarn workspaces foreach -v --all --parallel --include '@girs/*' run test",
		"check:app": "yarn workspaces foreach -v --all --include '@ts-for-gir/*' --include '@gi.ts/*' -pti run check",
		"check": "yarn check:lint && yarn check:app",
		"update:submodules": "git submodule foreach git pull",
		"update:packages": "yarn upgrade-interactive",
		"update": "yarn update:submodules && yarn update:packages",
		"publish:app": "yarn build:app && yarn workspaces foreach -v --all --parallel --no-private --include '@ts-for-gir/*' --include '@gi.ts/*' npm publish --tolerate-republish --tag latest --access public --provenance",
		"publish:types": "yarn workspaces foreach -v --all --parallel --no-private --include '@girs/*' npm publish --tolerate-republish --tag latest --access public",
		"publish": "yarn publish:app && yarn publish:types",
		"test:types": "yarn build:types && yarn check:types",
		"test:examples": "yarn build:examples && yarn check:examples && yarn test:examples:cli",
		"test:examples:cli": "yarn workspace @ts-for-gir-example/glib-2-spawn-command-example run start && yarn workspace @ts-for-gir-example/gio-2-cat-example run start && yarn workspace @ts-for-gir-example/gobject-param-spec run start && yarn workspace @ts-for-gir-example/gio-2-async run start && yarn workspace @ts-for-gir-example/gio-2-action-entries run start && yarn workspace @ts-for-gir-example/gio-2-iterate run start",
		"test:tests": "yarn workspaces foreach -v --all --parallel --include '@ts-for-gir-test/*' --exclude '@ts-for-gir-test/e2e' run test",
		"test:e2e": "yarn build:app && yarn workspace @ts-for-gir-test/e2e run test",
		"test": "yarn build && yarn test:types && yarn test:examples && yarn test:tests",
		"release": "GITHUB_TOKEN=${GITHUB_TOKEN:-$(gh auth token)} release-it --preRelease=rc",
		"release:stable": "GITHUB_TOKEN=${GITHUB_TOKEN:-$(gh auth token)} release-it --no-github.preRelease",
		"release:dry": "GITHUB_TOKEN=${GITHUB_TOKEN:-$(gh auth token)} release-it --preRelease=rc --dry-run",
		"prepare": "husky"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gjsify/ts-for-gir.git"
	},
	"bugs": {
		"url": "https://github.com/gjsify/ts-for-gir/issues"
	},
	"author": "Pascal Garber <pascal@mailfreun.de>",
	"license": "Apache-2.0",
	"homepage": "https://github.com/gjsify/ts-for-gir#readme",
	"keywords": [
		"gjs",
		"typescript",
		"generate",
		"gir",
		"gobject-introspection",
		"gnome",
		"gtk",
		"glib",
		"gobject",
		"dts",
		"type definitions"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@release-it/bumper": "^7.0.5",
		"@release-it/conventional-changelog": "^10.0.6",
		"@ts-for-gir/cli": "workspace:^",
		"concurrently": "^9.2.1",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"husky": "^9.1.7",
		"release-it": "^19.2.4",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.2"
	},
	"workspaces": [
		"examples/*",
		"tests/*",
		"packages/*",
		"types-dev/*"
	],
	"dependenciesMeta": {
		"@swc/core": {
			"built": true
		},
		"esbuild": {
			"built": true
		},
		"lmdb": {
			"built": true
		},
		"msgpackr-extract": {
			"built": true
		}
	},
	"packageManager": "yarn@4.13.0"
}
