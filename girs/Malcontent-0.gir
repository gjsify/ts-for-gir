    <record name="SessionLimits"
            c:type="MctSessionLimits"
            opaque="1"
            version="0.5.0"
            glib:type-name="MctSessionLimits"
            glib:get-type="mct_session_limits_get_type"
            c:symbol-prefix="session_limits">
      <doc xml:space="preserve"
           filename="libmalcontent/session-limits.h"
           line="35">An opaque, immutable structure which contains a snapshot
of the session limits settings for a user at a given time.

This includes whether session limits are being enforced, and the limit
policy — for example, the times of day when a user is allowed to use the
computer.

Typically, session limits settings can only be changed by the administrator,
and are read-only for non-administrative users. The precise policy is set
using polkit.</doc>
      <source-position filename="libmalcontent/session-limits.h" line="51"/>
      <method name="check_time_remaining"
              c:identifier="mct_session_limits_check_time_remaining"
              version="0.14.0">
        <doc xml:space="preserve"
             filename="libmalcontent/session-limits.c"
             line="195">Check whether the user has time remaining in which they are allowed to use
the computer.

This assumes that @now_dt is the current time and
@active_session_time_today_secs is the total amount of time the user has
spent in an active session up to that point today, and applies the
session limit policy from @limits to them.

This will return whether the user is allowed to use the computer now; further
information about the policy and remaining time is provided in
@time_remaining_secs_out and @time_limit_enabled_out.</doc>
        <source-position filename="libmalcontent/session-limits.h" line="70"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libmalcontent/session-limits.c"
               line="220">true if the user this @limits corresponds to is allowed to be in
  an active session at the given time; false otherwise</doc>
          <type name="gboolean" c:type="gboolean"/>
        </return-value>
        <parameters>
          <instance-parameter name="limits" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libmalcontent/session-limits.c"
                 line="197">a [struct@Malcontent.SessionLimits]</doc>
            <type name="SessionLimits" c:type="MctSessionLimits*"/>
          </instance-parameter>
          <parameter name="now_dt" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libmalcontent/session-limits.c"
                 line="198">current time in the user’s timezone, typically queried using
  `g_date_time_new_now_local()`</doc>
            <type name="GLib.DateTime" c:type="GDateTime*"/>
          </parameter>
          <parameter name="active_session_time_today_secs"
                     transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libmalcontent/session-limits.c"
                 line="200">total time the user has spent in an active
  session so far today, in seconds</doc>
            <type name="guint64" c:type="uint64_t"/>
          </parameter>
          <parameter name="time_remaining_secs_out"
                     direction="out"
                     caller-allocates="0"
                     transfer-ownership="full"
                     optional="1"
                     allow-none="1">
            <doc xml:space="preserve"
                 filename="libmalcontent/session-limits.c"
                 line="202">return location for the number
  of seconds remaining before the user’s session has to end, if limits are
  in force</doc>
            <type name="guint64" c:type="guint64*"/>
          </parameter>
          <parameter name="time_limit_enabled_out"
                     direction="out"
                     caller-allocates="0"
                     transfer-ownership="full"
                     optional="1"
                     allow-none="1">
            <doc xml:space="preserve"
                 filename="libmalcontent/session-limits.c"
                 line="205">return location for whether time
  limits are enabled for this user</doc>
            <type name="gboolean" c:type="gboolean*"/>
          </parameter>
        </parameters>
      </method>
