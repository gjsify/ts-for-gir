            <doc xml:space="preserve"
                 filename="libgimp/gimpdrawable.c"
                 line="592">The effect name which will show in undo step.</doc>
            <type name="utf8" c:type="const gchar*"/>
          </parameter>
          <parameter name="mode" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimpdrawable.c"
                 line="593">The blend mode.</doc>
            <type name="LayerMode" c:type="GimpLayerMode"/>
          </parameter>
          <parameter name="opacity" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimpdrawable.c"
                 line="594">The opacity from 0.0 (transparent) to 1.0 (opaque).</doc>
            <type name="gdouble" c:type="gdouble"/>
          </parameter>
