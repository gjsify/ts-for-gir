              c:identifier="meta_window_raise_and_make_recent_on_workspace">
        <doc xml:space="preserve"
             filename="src/core/window.c"
             line="5408">Raises a window and marks it as the most recently used window on the
workspace @target_workspace. If the window exists on all workspaces, it will
become the most recently used sticky window on all other workspaces. This
ensures proper tracking among windows on all workspaces while not overriding
MRU for other windows.</doc>
        <source-position filename="src/meta/window.h" line="311"/>
        <return-value transfer-ownership="none">
