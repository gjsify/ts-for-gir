          <parameter name="file" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimpimage_pdb.c"
                 line="1340">The SVG file to create.</doc>
            <type name="Gio.File" c:type="GFile*"/>
          </parameter>
          <parameter name="path"
                     transfer-ownership="none"
                     nullable="1"
                     allow-none="1">
