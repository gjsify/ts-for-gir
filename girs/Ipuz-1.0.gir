        </return-value>
        <parameters>
          <instance-parameter name="self" transfer-ownership="none">
            <type name="Grid" c:type="IpuzGrid*"/>
          </instance-parameter>
        </parameters>
      </method>
      <method name="fix_guesses" c:identifier="ipuz_grid_fix_guesses">
