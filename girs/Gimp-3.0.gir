                         line="62"/>
        <return-value transfer-ownership="full">
          <doc xml:space="preserve"
               filename="libgimp/gimpdrawablefilter_pdb.c"
               line="586">
         The list of GEGL operation names.
         The returned value must be freed with g_strfreev().</doc>
