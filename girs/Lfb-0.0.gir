      <glib:signal name="feedback-ended" when="last">
        <doc xml:space="preserve"
             filename="data/lfb-gdbus.c"
             line="1705">On the client-side, this signal is emitted whenever the D-Bus signal &lt;link linkend="gdbus-signal-org-sigxcpu-Feedback.FeedbackEnded"&gt;"FeedbackEnded"&lt;/link&gt; is received.

