      <method name="is_internal"
              c:identifier="gimp_procedure_is_internal"
              version="3.0">
        <doc xml:space="preserve"
             filename="libgimp/gimpprocedure.c"
             line="2235">Provide the information if @procedure is an internal procedure. Only
a procedure looked up in the [class@Gimp.PDB] can be internal.
