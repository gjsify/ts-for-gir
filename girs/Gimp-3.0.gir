        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimp/gimpprocedure.c"
               line="2243">Whether @procedure is an internal procedure or not.</doc>
          <type name="gboolean" c:type="gboolean"/>
        </return-value>
