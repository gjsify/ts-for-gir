    <class name="LinkLayer"
           c:symbol-prefix="link_layer"
           c:type="GimpLinkLayer"
           parent="Layer"
           glib:type-name="GimpLinkLayer"
           glib:get-type="gimp_link_layer_get_type"
           glib:type-struct="LinkLayerClass">
      <doc xml:space="preserve"
           filename="libgimp/gimplinklayer_pdb.c"
           line="30">Functions for querying and manipulating link layers.</doc>
      <source-position filename="libgimp/gimplinklayer.h" line="38"/>
      <implements name="Rasterizable"/>
      <constructor name="new" c:identifier="gimp_link_layer_new" version="3.2">
        <doc xml:space="preserve"
             filename="libgimp/gimplinklayer_pdb.c"
             line="39">Create a new link layer.

This procedure creates a link layer monitoring the specified @file.

The new layer still needs to be added to the image as this is not
automatic. Add the new layer with the [method@Image.insert_layer]
method.

The arguments are kept as simple as necessary for the basic case.
All link attributes, however, can be modified with the appropriate
`gimp_link_layer_set_*()` procedures.</doc>
        <source-position filename="libgimp/gimplinklayer_pdb.h" line="35"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimp/gimplinklayer_pdb.c"
               line="56">
         The new link layer. The object belongs to libgimp and you should not free it.</doc>
          <type name="LinkLayer" c:type="GimpLinkLayer*"/>
        </return-value>
        <parameters>
          <parameter name="image" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimplinklayer_pdb.c"
                 line="41">The image.</doc>
            <type name="Image" c:type="GimpImage*"/>
          </parameter>
          <parameter name="file" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimplinklayer_pdb.c"
                 line="42">The file this link layer will monitor.</doc>
            <type name="Gio.File" c:type="GFile*"/>
          </parameter>
        </parameters>
      </constructor>
      <function name="get_by_id"
                c:identifier="gimp_link_layer_get_by_id"
                version="3.2">
        <doc xml:space="preserve"
             filename="libgimp/gimplinklayer.c"
             line="52">Returns a #GimpLinkLayer representing @layer_id. This function calls
[func@Gimp.Item.get_by_id] and returns the item if it is a link
layer or %NULL otherwise.</doc>
        <source-position filename="libgimp/gimplinklayer.h" line="41"/>
        <return-value transfer-ownership="none" nullable="1">
          <doc xml:space="preserve"
               filename="libgimp/gimplinklayer.c"
               line="60">a #GimpLinkLayer for @layer_id or
         %NULL if @layer_id does not represent a valid link layer. The
         object belongs to libgimp and you must not modify or unref
         it.</doc>
          <type name="LinkLayer" c:type="GimpLinkLayer*"/>
        </return-value>
        <parameters>
          <parameter name="layer_id" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimplinklayer.c"
                 line="54">The layer id.</doc>
            <type name="gint32" c:type="gint32"/>
          </parameter>
        </parameters>
      </function>
      <method name="get_file"
              c:identifier="gimp_link_layer_get_file"
              version="3.2">
        <doc xml:space="preserve"
             filename="libgimp/gimplinklayer_pdb.c"
             line="87">Get the monitored file.

This procedure returns the file which is being monitored.</doc>
        <source-position filename="libgimp/gimplinklayer_pdb.h" line="37"/>
        <return-value transfer-ownership="full">
          <doc xml:space="preserve"
               filename="libgimp/gimplinklayer_pdb.c"
               line="95">The monitored file.</doc>
          <type name="Gio.File" c:type="GFile*"/>
        </return-value>
        <parameters>
          <instance-parameter name="layer" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimplinklayer_pdb.c"
                 line="89">The link layer.</doc>
            <type name="LinkLayer" c:type="GimpLinkLayer*"/>
          </instance-parameter>
        </parameters>
      </method>
      <method name="get_mime_type"
              c:identifier="gimp_link_layer_get_mime_type"
              version="3.2">
        <doc xml:space="preserve"
             filename="libgimp/gimplinklayer_pdb.c"
             line="162">Get the mime type of the monitored file.

This procedure returns the mime type of the file which is being
monitored by @layer.

Note that this will be the real mime type, corresponding to our
format support, as returned by the [class@Gimp.LoadProcedure] which
actually performs the external image file import.

This function may also return %NULL in case of error (for instance
if the external file doesn't exist anymore).</doc>
        <source-position filename="libgimp/gimplinklayer_pdb.h" line="40"/>
        <return-value transfer-ownership="full">
          <doc xml:space="preserve"
               filename="libgimp/gimplinklayer_pdb.c"
               line="178">The mime type of the monitored file.
         The returned value must be freed with g_free().</doc>
          <type name="utf8" c:type="gchar*"/>
        </return-value>
        <parameters>
          <instance-parameter name="layer" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimplinklayer_pdb.c"
                 line="164">The link layer.</doc>
            <type name="LinkLayer" c:type="GimpLinkLayer*"/>
          </instance-parameter>
        </parameters>
      </method>
      <method name="set_file"
              c:identifier="gimp_link_layer_set_file"
              version="3.2">
        <doc xml:space="preserve"
             filename="libgimp/gimplinklayer_pdb.c"
             line="123">Set the monitored file.

This procedure sets the file to be monitored. It may change the
layer's render.</doc>
        <source-position filename="libgimp/gimplinklayer_pdb.h" line="38"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libgimp/gimplinklayer_pdb.c"
               line="133">TRUE on success.</doc>
          <type name="gboolean" c:type="gboolean"/>
        </return-value>
        <parameters>
          <instance-parameter name="layer" transfer-ownership="none">
            <doc xml:space="preserve"
