          </instance-parameter>
          <parameter name="mask_only" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libgimp/gimpdrawablecolor_pdb.c"
                 line="399">Equalization option.</doc>
            <type name="gboolean" c:type="gboolean"/>
          </parameter>
        </parameters>
      </method>
