            <doc xml:space="preserve"
                 filename="libipuz/ipuz-grid.c"
                 line="1329">The guesses to check</doc>
            <type name="Guesses" c:type="IpuzGuesses*"/>
          </parameter>
          <parameter name="check_type" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="libipuz/ipuz-grid.c"
